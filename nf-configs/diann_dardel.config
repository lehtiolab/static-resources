external_config_version = 'main'
includeConfig "https://raw.githubusercontent.com/lehtiolab/static-resources/${external_config_version}/nf-configs/pdc_dardel.config"

params {
  batchsize = 1
}


def getsize_raw_or_bruker(dir_or_fn) {
  if (dir_or_fn.isDirectory()) {
    def outfn
    dir_or_fn.toRealPath().eachFileMatch("analysis.tdf_bin") { it -> outfn = it }
    return outfn.size()

  } else if (dir_or_fn.isFile()) {
    return dir_or_fn.size()
  }
}


process {
  cpus = 10
  
  withName: predictFastaLibrary {
    // Either 200 * lib size, or 16GB whatever is bigger
    memory = { Math.max(fasta.collect { it.size() }.sum() * 200, 16L << 30) * 1.B }
  }

  withName: searchWithPredictedLib {
    time = { raws.size() * 3.h }
    // biggest raw times 4, or 16.GB
    memory = { Math.max(raws.collect { getsize_raw_or_bruker(it) }.max() * 4, 16L << 30) * 1.B }
  }

  withName: combineEmpiricalLibraryRuns  {
    // sum raws, divide by 20, set that as memory, if bigger than 16G
    // need to convert to long for Math.max(long, long) or it will error w ambiguous method overload
    memory = { Math.max(raws.collect { getsize_raw_or_bruker(it) / 20 }.sum().longValue(), 16L << 30) * 1.B }
  }

  withName: RunDiaAnalysis {
    // biggest raw times 4, or 16.GB
    memory = { Math.max(raws.collect { getsize_raw_or_bruker(it) }.max() * 4, 16L << 30) * 1.B }
  }

  withName: TrainQuantUMS {
    memory = { Math.max(raws.collect { getsize_raw_or_bruker(it) }.max() * 10, 16L << 30) * 1.B }
  }

  withName: DiaQuantificationReport {
    memory = { Math.max(raws.collect { getsize_raw_or_bruker(it) }.max() * 10, 16L << 30) * 1.B }
  }

  withName: logConcat {
    cpus = 1
  }
}
